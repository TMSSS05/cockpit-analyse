# ─── Market Analysis Cockpit ──────────────────────────────
# Copiez ce fichier en .env et ajustez les valeurs

# Mode données
MAC_USE_MOCK_DATA=false     # true → données simulées (pas de yfinance)
MAC_YFINANCE_ENABLED=true   # false → désactive yfinance
MAC_CCXT_ENABLED=true       # false → désactive ccxt

# Serveur
MAC_HOST=0.0.0.0
MAC_PORT=8000
MAC_CORS_ORIGINS=http://localhost:3000

# Cache DuckDB
MAC_DUCKDB_PATH=./data/market_data.duckdb
MAC_CACHE_EXPIRE_HOURS=1    # Durée de vie du cache en heures
